// SCOPE AND CLOSURE ,HOF

//SCOPE : 1.global  2.local  3.block



function create(){
    let cnt=0;
    function inner(){
        cnt++;
        return cnt;
    }
    return inner;
}

const counter=create();
console.log(counter());



function outer(){

    let balance=500;


    const user={
    deposit: function(amount){
        if(typeof amount==="number" && amount>0){
            balance+=amount;
            return balance;
        }
    },
    withdraw: function(amount){
        if(typeof amount==="number" && amount>0 && amount<=balance){
            balance-=amount;
            return balance;
        }    },
    getBalance: function(){
        return balance;
    }


}
return user;
}
const customer=outer();
console.log(customer.getBalance()); // 500
console.log(customer.deposit(200));


