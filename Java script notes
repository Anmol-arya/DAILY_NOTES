// difference between slice and splice

// slice: it is used to extract a portion of the array and returns a new array. It does not modify the original array.
// splice: it is used to add or remove elements from the array. It modifies the original array.

const arr1=[1,2,3,4,5];
const arr2=arr1.slice(1,4);
console.log(arr1);
console.log(arr2);


const arr3=[1,2,3,4,5];
arr3.splice(1,2);
console.log(arr3);

